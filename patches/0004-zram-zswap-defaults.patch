From: LegendaryOS Build System <build@legendaryos.linux>
Date: Sat, 27 Jun 2026 00:00:00 +0000
Subject: [PATCH 04/10] mm: enable ZRAM and ZSWAP built-in with zstd compression

ZRAM jako urządzenie blokowe dla swapa oraz ZSWAP jako cache swap
skompresowanego w RAMie — oba z algorytmem zstd (najlepszy stosunek
prędkości do kompresji). Zapobiega thrashingowi przy grach zajmujących
16–32 GB RAM.

Signed-off-by: LegendaryOS Build System <build@legendaryos.linux>
---
 drivers/block/Kconfig | 4 ++++
 mm/Kconfig            | 6 ++++++
 1 file changed, 10 insertions(+)

diff --git a/drivers/block/Kconfig b/drivers/block/Kconfig
index ccccccc..ddddddd 100644
--- a/drivers/block/Kconfig
+++ b/drivers/block/Kconfig
@@ -42,3 +42,7 @@ config BLK_DEV_LOOP
 
+config ZRAM
+	tristate "Compressed RAM block device (LegendaryOS: built-in)"
+	default y
+	select ZSTD_COMPRESS
+	select ZSTD_DECOMPRESS
diff --git a/mm/Kconfig b/mm/Kconfig
@@ -200,3 +200,9 @@ config ZSWAP
 
+config ZSWAP_COMPRESSOR_DEFAULT_ZSTD
+	bool "Use zstd as default ZSWAP compressor"
+	default y
+	depends on ZSWAP
