# LegendaryOS patch 0007 — Wyłącz NMI watchdog
# NMI watchdog przerywa wszystkie rdzenie co sekundę przez Non-Maskable
# Interrupt żeby wykryć kernel lockup. Powoduje latency spikes ~1ms
# widoczne jako mikro-stuttery przy 165+ Hz / 240 Hz.
# Można przywrócić parametrem boot: nmi_watchdog=1
# CONFIG_HARDLOCKUP_DETECTOR is not set
CONFIG_HARDLOCKUP_DETECTOR_PERF=n
