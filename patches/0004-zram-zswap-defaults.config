# LegendaryOS patch 0004 — ZRAM + ZSWAP z kompresją zstd
# ZRAM: skompresowane urządzenie blokowe w RAMie używane jako swap.
# ZSWAP: cache dla stron swapowanych — trzyma je skompresowane w RAM
# zamiast pisać na dysk. Algorytm zstd: najlepszy stosunek prędkości
# do stopnia kompresji. Zapobiega stutterom przy braku RAM w grach.
CONFIG_ZRAM=y
CONFIG_ZRAM_DEF_COMP_ZSTD=y
CONFIG_ZSWAP=y
CONFIG_ZSWAP_COMPRESSOR_DEFAULT_ZSTD=y
CONFIG_ZSWAP_ZPOOL_DEFAULT_ZSMALLOC=y
CONFIG_ZSMALLOC=y
CONFIG_ZSTD_COMPRESS=y
CONFIG_ZSTD_DECOMPRESS=y
