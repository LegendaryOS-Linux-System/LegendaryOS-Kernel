# LegendaryOS patch 0009 — NVIDIA akmod compatibility
# Wymagane przez sterownik akmod-nvidia >= 550 (RTX 30xx/40xx/50xx).
#
# KALLSYMS_ALL: eksportuje wszystkie symbole kernela — wymagane przez
# zamknięty sterownik NVIDIA do resolwowania adresów funkcji kernela.
#
# DMABUF_HEAPS: alokator DMA-BUF heap wymagany przez NVIDIA GSP
# (GPU System Processor — firmware RTX 30xx+). Bez tego akmod-nvidia
# 550+ nie załaduje się na kartach z GSP.
#
# Nouveau wyłączony: konflikt z proprietary driverem.
CONFIG_KALLSYMS_ALL=y
CONFIG_DMABUF_HEAPS=y
CONFIG_DMABUF_HEAPS_SYSTEM=y
CONFIG_DMABUF_HEAPS_CMA=y
# CONFIG_DRM_NOUVEAU is not set

# Resizable BAR (Smart Access Memory dla NVIDIA)
# Pozwala CPU mapować pełny VRAM przez PCIe — +10-30% transfer CPU<->GPU
# Wymaga: BIOS z 4G Decoding + Above 4G MMIO enabled
CONFIG_PCI_REALLOC_ENABLE_AUTO=y
