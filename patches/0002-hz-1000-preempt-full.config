# LegendaryOS patch 0002 — HZ=1000 + PREEMPT_DYNAMIC
# HZ=1000: timer systemowy 1000 razy na sekundę zamiast domyślnych 250.
# Niższe opóźnienia wejściowe (input latency), lepszy response desktopa i gier.
# PREEMPT_DYNAMIC: pełna wywłaszczalność jądra z możliwością zmiany w runtime.
CONFIG_HZ_1000=y
CONFIG_HZ=1000
# CONFIG_HZ_250 is not set
# CONFIG_HZ_300 is not set
CONFIG_PREEMPT_DYNAMIC=y
CONFIG_PREEMPT=y
# CONFIG_PREEMPT_VOLUNTARY is not set
# CONFIG_PREEMPT_NONE is not set
