# LegendaryOS patch 0006 — CPU governor performance + AMD pstate EPP
# Domyślny governor "performance" zamiast "powersave" z Fedory.
# Dla AMD Zen 3/4: amd-pstate w trybie active (EPP) z profilem performance.
# CPU podbija taktowanie natychmiast na obciążenie → niższa input latency.
CONFIG_CPU_FREQ_DEFAULT_GOV_PERFORMANCE=y
# CONFIG_CPU_FREQ_DEFAULT_GOV_POWERSAVE is not set
# CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL is not set
CONFIG_X86_AMD_PSTATE=y
CONFIG_X86_AMD_PSTATE_DEFAULT_MODE=3
