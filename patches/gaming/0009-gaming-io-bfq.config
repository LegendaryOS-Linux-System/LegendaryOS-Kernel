# LegendaryOS patch 0009 — BFQ I/O scheduler jako domyślny
# BFQ (Budget Fair Queueing): scheduler I/O zoptymalizowany pod desktop.
# Priorytetyzuje interaktywne procesy (gra, pulpit) nad background I/O
# (dnf, tracker-miner, systemd-journal).
# Eliminuje stuttery przy ładowaniu assetów ze SSD/NVMe podczas gry.
CONFIG_IOSCHED_BFQ=y
CONFIG_BFQ_GROUP_IOSCHED=y
CONFIG_DEFAULT_IOSCHED="bfq"
# CONFIG_DEFAULT_DEADLINE is not set
# CONFIG_DEFAULT_KYBER is not set

# Dodatkowe: włącz BFQ dla NVMe (domyślnie używa none/mq-deadline)
CONFIG_BLK_MQ_IOSCHED_BFQ=y
