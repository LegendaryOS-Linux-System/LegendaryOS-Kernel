# LegendaryOS patch 0010 — Scheduler latency tuning dla gier
# Mniejsze okna schedulera = niższe opóźnienia wejściowe (input lag).
# sched_ext: BPF-extensible scheduler — pozwala ładować zewnętrzne
# schedulery (np. scx_lavd, scx_bpfland) w runtime bez restartu.
# Współgra z BORE gdy załadowany jest bore-sched przez scx.
CONFIG_SCHED_CLASS_EXT=y
CONFIG_SCHED_DEBUG=n
# Mniejsze minimum granularity schedulera = lepszy response
CONFIG_SCHED_SMT=y
CONFIG_SCHED_MC=y
CONFIG_SCHED_MC_PRIO=y
