# LegendaryOS patch 0005 — BBR v3 jako domyślny TCP congestion control
# BBR (Bottleneck Bandwidth and RTT) v3: niższe latencje sieciowe
# i wyższy throughput w grach online vs domyślny CUBIC.
# FQ (Fair Queue) packet scheduler wymagany przez BBR.
CONFIG_TCP_CONG_BBR=y
CONFIG_NET_SCH_FQ=y
CONFIG_DEFAULT_TCP_CONG="bbr"
